---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <div>
        <h2 class="font-cyberblast text-7xl ml-8 mt-4">Upload</h2>
        <div class="shimmer" id="loadingState">
            <p class="text-center text-green-400 text-lg">Loading...</p>
        </div>
        <form
            class="outline-2 outline-amber-500 w-[70%] mt-8 ml-auto mr-auto p-16 flex flex-col gap-6 rounded-2xl"
            id="upload-form"
        >
            <div class="flex flex-col gap-2">
                <label>Enter the name of the clip</label>
                <input
                    type="text"
                    name="title"
                    placeholder="Enter title"
                    class="input input-lg w-[70%]"
                    required
                />
            </div>
            <div class="flex flex-col gap-2">
                <label>Who made the movie?</label>
                <input
                    type="text"
                    name="who"
                    placeholder="Enter names"
                    class="input input-lg w-[70%]"
                    required
                />
            </div>
            <div class="flex flex-col gap-2">
                <input
                    type="file"
                    name="video"
                    accept="video/mp4"
                    class="file-input file-input-primary file-input-xl"
                    required
                />
            </div>
            <div class="flex flex-col gap-2">
                <label>PIN</label>
                <input
                    type="password"
                    name="pin"
                    placeholder="Enter PIN"
                    class="input input-lg w-[70%]"
                    required
                />
            </div>
            <button type="submit" class="btn btn-accent btn-xl">Upload!</button>
        </form>
        <p id="status" class="text-center mt-4 hidden"></p>
    </div>
</Layout>

<style>
    .shimmer {
        color: grey;
        display: block;
        mask: linear-gradient(-60deg, #000 30%, #0005, #000 70%) right/350% 100%;
        animation: shimmer 2.5s infinite;
        font-size: 50px;
        width: fit-content;
        margin-left: auto;
        margin-right: auto;
        visibility: hidden;
    }

    @keyframes shimmer {
        100% {
            mask-position: left;
        }
    }
</style>

<script>
    const uploadForm = document.getElementById(
        "upload-form",
    ) as HTMLFormElement;
    const status = document.getElementById("status") as HTMLParagraphElement;
    const loadingElement = document.getElementById(
        "loadingState",
    ) as HTMLParagraphElement;

    uploadForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        status?.classList.add("hidden");
        loadingElement.style.visibility = "visible";
        const formData = new FormData(uploadForm);
        const file = formData.get("video") as File;

        if (!file || !(file instanceof File) || file.size === 0) {
            alert("Please select a video file.");
            return;
        }

        try {
            const authResponse = await fetch("/api/upload", {
                method: "POST",
                body: JSON.stringify({
                    title: formData.get("title"),
                    who: formData.get("who"),
                    fileName: file.name,
                    fileType: file.type,
                    contentType: file.type,
                    pin: formData.get("pin"),
                }),
            });

            const { url } = await authResponse.json();
            const uploadResponse = await fetch(url, {
                method: "PUT",
                body: file,
                headers: { "Content-Type": file.type },
            });

            if (uploadResponse.ok) alert("Video uploaded");
        } catch (error) {
            status.textContent = "Network Error";
            status.className = "text-center mt-4 text-red-600";
            console.error("There was an error uploading the video: ", error);
        }
        status.classList.remove("hidden");
        loadingElement.style.visibility = "hidden";
    });
</script>
